---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';

const faqs = [
  {
    q: "Quel est le tarif pour un débouchage de canalisation en Belgique ?",
    a: "Chez Plombier Urgence, le tarif pour un débouchage de canalisation démarre à 60€ TTC, inspection caméra incluse. Pour un WC bouché, le tarif est de 75€ à 150€ selon la complexité. Ces prix sont fixes et communiqués avant toute intervention, conformément à la loi belge sur la transparence des services."
  },
  {
    q: "En combien de temps un plombier d'urgence peut-il intervenir en Belgique ?",
    a: "Nos plombiers interviennent en moins de 30 minutes dans toute la Belgique — Bruxelles, Liège, Namur, Charleroi et Mons. Notre réseau de techniciens répartis stratégiquement garantit un temps de réponse moyen de 23 minutes, 24h/24 et 7j/7, y compris les week-ends et jours fériés."
  },
  {
    q: "Les plombiers de Plombier Urgence sont-ils certifiés ?",
    a: "Oui. Tous nos techniciens sont certifiés et agréés en Belgique, avec plus de 15 ans d'expérience cumulée. Nos plombiers chauffagistes détiennent les certifications CP1/CP2 requises par Synergrid pour les interventions sur installations de gaz. Toutes nos réparations sont garanties 2 ans pièces et main d'œuvre."
  },
  {
    q: "Plombier Urgence intervient-il la nuit et le week-end ?",
    a: "Oui, Plombier Urgence est disponible 24h/24, 7j/7, y compris la nuit, les dimanches et les jours fériés belges. Un supplément de 30% à 50% peut s'appliquer pour les interventions entre 20h et 7h ou les week-ends — ce montant est toujours communiqué avant l'intervention."
  },
  {
    q: "Que faire en cas de fuite d'eau urgente chez soi en Belgique ?",
    a: "En cas de fuite d'eau urgente : 1) Fermez immédiatement le robinet d'arrêt général (généralement sous l'évier ou dans la cave). 2) Coupez l'électricité dans les zones humides. 3) Appelez Plombier Urgence au 0465 68 51 58 — nos techniciens arrivent en moins de 30 minutes. Une fuite non traitée peut causer jusqu'à 150 litres de perte par jour et aggraver les dommages structurels."
  },
  {
    q: "Comment déboucher un WC bouché rapidement ?",
    a: "Pour déboucher un WC : commencez par une ventouse (5 à 10 pompes vigoureuses). Si cela échoue, un furet mécanique peut atteindre les bouchons à 1–3 mètres de profondeur. Évitez les produits chimiques — ils corrodent les canalisations anciennes en PVC. Si le problème persiste, notre équipe intervient dès 75€ avec hydrocurage haute pression, garantie 6 mois."
  },
  {
    q: "Plombier Urgence couvre-t-il toute la Belgique ?",
    a: "Plombier Urgence couvre l'ensemble de la Belgique francophone : Bruxelles et ses 19 communes, le Brabant wallon, la Province de Liège, la Province de Namur, le Hainaut (Charleroi, Mons, Tournai, La Louvière) et le Brabant flamand (Louvain, Vilvorde, Zaventem). Soit plus de 40 villes et communes couvertes en moins de 30 minutes."
  }
];
---

<Layout 
  title="Plombier Belgique — Urgence 24/7 & Tarifs Clairs | Plombier Urgence" 
  description="Plombier Belgique 24h/24 : débouchage dès 60€, fuite dès 95€. Intervention 30 min. Prix fixes, sans surprise. ☎ 0465 68 51 58"
  {faqs}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__bg"></div>
    <div class="container hero__inner">
      <div class="hero__badge">💰 Le seul plombier en Belgique qui affiche ses prix</div>
      <h1 class="hero__title">
        Plombier Belgique — Urgence 24/7
        <span class="text-accent">Intervention en 30 min</span>
      </h1>
      <p class="hero__subtitle">
        Le seul plombier en Belgique qui affiche ses prix avant d'intervenir. Plus de <strong>2 000 interventions</strong> réalisées. Temps de réponse moyen : <strong>23 minutes</strong>. Débouchage dès 60€ | Fuite dès 95€ | Disponible maintenant.
      </p>
      <div class="hero__actions">
        <a href="tel:0465685158" class="btn btn-primary btn-lg">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
          Appeler Maintenant
        </a>
        <a href="/tarifs" class="btn btn-outline btn-lg">Voir les Tarifs</a>
      </div>
      <div class="hero__stats">
        <div class="hero__stat">
          <span class="hero__stat-number">15+</span>
          <span class="hero__stat-label">Années d'exp.</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-number">5 000+</span>
          <span class="hero__stat-label">Clients satisfaits</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-number">30 min</span>
          <span class="hero__stat-label">Délai moyen</span>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <span class="hero__stat-number">4.9/5</span>
          <span class="hero__stat-label">500+ avis</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section" id="services">
    <div class="container text-center">
      <p class="section-label">Nos Services</p>
      <h2 class="section-title">Plombier Belgique — Services de Plomberie Complets</h2>
      <p class="section-subtitle">Votre plombier en Belgique pour tous vos problèmes de plomberie. Interventions rapides et efficaces partout dans le pays.</p>
    </div>
    <div class="container grid grid-3">
      <ServiceCard
        icon="🚿"
        title="Débouchage Canalisation"
        description="WC, évier, douche ou baignoire bouchés ? Nous intervenons avec du matériel haute pression pour un débouchage immédiat."
        image="/images/service-debouchage.webp"
      />
      <ServiceCard
        icon="🔍"
        title="Recherche de Fuite"
        description="Détection précise de fuites d'eau sans casse grâce à nos caméras thermiques et acoustiques. Réparation rapide garantie."
        image="/images/service-fuite.webp"
      />
      <ServiceCard
        icon="🔥"
        title="Dépannage Chaudière"
        description="Votre chaudière est en panne ? Plus d'eau chaude ? Nos chauffagistes agréés interviennent sur toutes les marques."
        image="/images/service-chaudiere.webp"
      />
      <ServiceCard
        icon="🔧"
        title="Réparation Robinetterie"
        description="Remplacement de robinets, mitigeurs, chasse d'eau qui coule. Installation de nouveaux sanitaires."
        image="/images/service-robinetterie.webp"
      />
      <ServiceCard
        icon="🛁"
        title="Rénovation Salle de Bain"
        description="Projet de rénovation ? Nous installons douches italiennes, baignoires et meubles vasques modernes."
        image="/images/service-renovation.webp"
      />
      <ServiceCard
        icon="🚨"
        title="Urgence Plomberie"
        description="Dépannage plomberie express 24/7 : fuite d'eau, canalisation bouchée, panne de chaudière ou dégât des eaux. Intervention en 30 minutes."
        image="/images/hero-bg.webp"
      />
    </div>
  </section>

  <!-- Why Us -->
  <section class="section why-us" id="pourquoi-nous">
    <div class="container text-center">
      <p class="section-label">Pourquoi Nous Choisir</p>
      <h2 class="section-title">Le Plombier N°1 en Belgique</h2>
    </div>
    <div class="container why-us__grid">
      <div class="why-us__image-col">
        <img src="/images/about-team.webp" alt="Équipe de plombiers professionnels qualifiés et certifiés pour interventions d'urgence en Belgique" class="why-us__image" loading="lazy" decoding="async" width="800" height="533" />
      </div>
      <div class="why-us__content-col">
        <div class="why-card">
          <div class="why-card__icon">⚡</div>
          <h3 class="why-card__title">Intervention en 30 Minutes</h3>
          <p class="why-card__text">Nos équipes de plombiers sont réparties stratégiquement dans toute la Belgique pour garantir une arrivée rapide.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon">💰</div>
          <h3 class="why-card__title">Tarifs Fixes et Transparents</h3>
          <p class="why-card__text">Pas de mauvaise surprise. Nous vous communiquons une estimation avant toute intervention.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon">✅</div>
          <h3 class="why-card__title">Travail Garanti</h3>
          <p class="why-card__text">Toutes nos réparations sont garanties 2 ans pièces et main d'œuvre. Satisfaction assurée.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testimonials" id="avis">
    <div class="container text-center">
      <p class="section-label">Témoignages & Validation</p>
      <h2 class="section-title">Avis Clients — Meilleur Plombier Belgique</h2>
      
      <blockquote style="max-width:800px;margin:2rem auto;padding:1.5rem;background:var(--color-surface);border-left:4px solid var(--color-accent);border-radius:0 var(--radius-lg) var(--radius-lg) 0;text-align:left;">
        <p style="font-size:1.1rem;font-weight:600;font-style:italic;margin-bottom:0.5rem;">"Une urgence plomberie bien gérée, c'est 80% du dommage évité."</p>
        <footer style="font-size:0.9rem;color:var(--color-text-muted);font-weight:700;">— <cite>Jean-Pierre M., ingénieur en bâtiment CSTC (Centre Scientifique et Technique de la Construction)</cite></footer>
      </blockquote>
    </div>
    <div class="container grid grid-3">
      <div class="testimonial-card card">
        <div class="testimonial-card__stars">★★★★★</div>
        <p class="testimonial-card__text">"Intervention en moins de 20 minutes pour une fuite urgente. Travail propre et soigné. Je recommande vivement !"</p>
        <div class="testimonial-card__author">
          <div class="testimonial-card__avatar">ML</div>
          <div>
            <strong>Marie L.</strong>
            <span>Bruxelles</span>
          </div>
        </div>
      </div>
      <div class="testimonial-card card">
        <div class="testimonial-card__stars">★★★★★</div>
        <p class="testimonial-card__text">"Chaudière réparée en une heure un dimanche soir. Très professionnel et tarif correct. Merci !"</p>
        <div class="testimonial-card__author">
          <div class="testimonial-card__avatar">PD</div>
          <div>
            <strong>Pierre D.</strong>
            <span>Waterloo</span>
          </div>
        </div>
      </div>
      <div class="testimonial-card card">
        <div class="testimonial-card__stars">★★★★★</div>
        <p class="testimonial-card__text">"Rénovation complète de notre salle de bain. Résultat magnifique et dans le budget annoncé. Top !"</p>
        <div class="testimonial-card__author">
          <div class="testimonial-card__avatar">SB</div>
          <div>
            <strong>Sophie B.</strong>
            <span>Namur</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Zones preview -->
  <section class="section zones-preview">
    <div class="container text-center">
      <p class="section-label">Zones d'Intervention</p>
      <h2 class="section-title">Plombier Belgique — Toutes les Régions Couvertes</h2>
      <p class="section-subtitle">Votre plombier en Belgique : Bruxelles, Wallonie et Flandre. Nos équipes sont proches de chez vous.</p>
    </div>
    <div class="container">
      <div class="zones-grid">
        <div class="zone-chip">Bruxelles</div>
        <div class="zone-chip">Waterloo</div>
        <div class="zone-chip">Namur</div>
        <div class="zone-chip">Liège</div>
        <div class="zone-chip">Charleroi</div>
        <div class="zone-chip">Mons</div>
        <div class="zone-chip">Nivelles</div>
        <div class="zone-chip">Wavre</div>
        <div class="zone-chip">Ottignies</div>
        <div class="zone-chip">Uccle</div>
        <div class="zone-chip">Ixelles</div>
        <div class="zone-chip">Schaerbeek</div>
      </div>
      <div style="text-align: center; margin-top: var(--space-xl);">
        <a href="/zones" class="btn btn-outline">Voir toutes les zones →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner />
</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: var(--space-4xl) 0;
    min-height: 80vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(15, 23, 42, 0.95) 0%, rgba(15, 23, 42, 0.7) 100%),
      url('/images/hero-bg.webp') center/cover no-repeat;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-accent-glow);
    border: 1px solid rgba(80,160,226,0.2);
    color: var(--color-accent);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: var(--font-size-sm);
    font-weight: 600;
    margin-bottom: var(--space-xl);
    animation: fadeInUp 0.6s ease;
  }

  .hero__title {
    font-size: var(--font-size-5xl);
    font-weight: 900;
    line-height: 1.1;
    max-width: 700px;
    margin-bottom: var(--space-lg);
    color: #ffffff;
    animation: fadeInUp 0.6s ease 0.1s both;
  }

  .hero__title .text-accent {
    display: block;
    margin-top: var(--space-sm);
    color: var(--color-accent);
  }

  .hero__subtitle {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.85);
    max-width: 550px;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
    animation: fadeInUp 0.6s ease 0.2s both;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
    margin-bottom: var(--space-3xl);
    animation: fadeInUp 0.6s ease 0.3s both;
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg) var(--space-xl);
    max-width: fit-content;
    animation: fadeInUp 0.6s ease 0.4s both;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__stat-number {
    font-size: var(--font-size-2xl);
    font-weight: 800;
    color: var(--color-accent);
  }

  .hero__stat-label {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .hero__stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Section label */
  .section-label {
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  /* Why Us */
  .why-us {
    background: var(--color-bg-alt);
  }

  .why-us__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
  }

  .why-us__image {
    width: 100%;
    border-radius: var(--radius-xl);
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    object-fit: cover;
  }

  .why-us__content-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .why-card {
    text-align: left;
    padding: var(--space-lg);
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    transition: transform 0.3s ease;
  }

  .why-card:hover {
    transform: translateY(-5px);
    border-color: var(--color-accent);
  }

  .why-card__icon {
    font-size: 2rem;
    margin-bottom: var(--space-sm);
  }

  .why-card__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    margin-bottom: var(--space-sm);
  }

  .why-card__text {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.6;
  }

  /* Testimonials */
  .testimonial-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .testimonial-card__stars {
    color: #f59e0b;
    font-size: var(--font-size-lg);
    letter-spacing: 2px;
  }

  .testimonial-card__text {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.8;
    flex: 1;
    font-style: italic;
  }

  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .testimonial-card__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent-glow);
    color: var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: var(--font-size-sm);
  }

  .testimonial-card__author strong {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .testimonial-card__author span {
    font-size: var(--font-size-xs);
    color: var(--color-text-dim);
  }

  /* Zones preview */
  .zones-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .zone-chip {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: all var(--transition-base);
  }

  .zone-chip:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-2xl) 0;
    }

    .hero__stats {
      flex-wrap: wrap;
      gap: var(--space-md);
    }

    .hero__stat-divider {
      display: none;
    }

    .why-us__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
