---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { locationPages } from '../../data/location-details';

export function getStaticPaths() {
  return locationPages.map(loc => ({
    params: { location: loc.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;
---

<Layout title={loc.metaTitle} description={loc.metaDescription} faqs={loc.faqs}>

  <!-- Breadcrumb -->
  <section class="bc-section"><div class="container"><nav class="bc"><a href="/">Accueil</a><span>›</span><a href="/zones">Zones</a><span>›</span><span class="bc--current">Plombier {loc.city}</span></nav></div></section>

  <!-- Hero -->
  <section class="loc-hero">
    <div class="loc-hero__bg"></div>
    <div class="container loc-hero__inner">
      <div class="loc-hero__badge">📍 Plombier local — {loc.city}</div>
      <h1 class="loc-hero__title">Plombier <span class="text-accent">{loc.city}</span> — Urgence 24/7</h1>
      <p class="loc-hero__sub">Votre plombier de confiance à {loc.city} et dans toute la {loc.province}. Intervention en {loc.responseTime}, tarifs clairs 2025, prix fixe avant intervention.</p>
      <div class="loc-hero__chips">
        <span class="chip">📍 {loc.city} ({loc.postalCodes})</span>
        <span class="chip">👥 {loc.population} habitants</span>
        <span class="chip chip--accent">⚡ Intervention en {loc.responseTime}</span>
        <span class="chip">⭐ 4.9/5 — 500+ avis</span>
      </div>
      <div class="loc-hero__actions">
        <a href="tel:0470123456" class="btn btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
          0470 12 34 56
        </a>
        <a href="https://wa.me/32470123456" class="btn btn-outline btn-lg" target="_blank">WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- Neighborhoods & Response Times -->
  <section class="section" id="quartiers">
    <div class="container">
      <p class="label">Quartiers & Délais de réponse</p>
      <h2 class="section-title">Temps d'Intervention par Quartier à {loc.city}</h2>
      <p class="section-subtitle">Nos équipes sont positionnées stratégiquement pour couvrir chaque quartier rapidement.</p>
      <div class="nb-grid">
        {loc.neighborhoods.map((nb: {name: string; responseTime: string; highlight: string}) => (
          <div class="nb-card card">
            <div class="nb-card__header">
              <h3 class="nb-card__title">{nb.name}</h3>
              <span class="nb-card__time">⚡ {nb.responseTime}</span>
            </div>
            <p class="nb-card__text">{nb.highlight}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Driving Directions -->
  <section class="section section--alt" id="acces">
    <div class="container">
      <p class="label">Comment nous arrivons</p>
      <h2 class="section-title">Directions depuis les Points Clés de {loc.city}</h2>
      <div class="dir-list">
        {loc.directions.map((dir: {from: string; duration: string; route: string}) => (
          <div class="dir-item">
            <div class="dir-item__from">
              <span class="dir-item__icon">📍</span>
              <strong>{dir.from}</strong>
            </div>
            <div class="dir-item__info">
              <span class="dir-item__time">🚐 {dir.duration}</span>
              <p class="dir-item__route">{dir.route}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Weather Challenges -->
  <section class="section" id="meteo">
    <div class="container">
      <p class="label">Défis saisonniers</p>
      <h2 class="section-title">Problèmes de Plomberie par Saison à {loc.city}</h2>
      <p class="section-subtitle">Chaque saison apporte ses défis. Voici comment nous vous protégeons toute l'année.</p>
      <div class="weather-grid">
        {loc.weatherChallenges.map((w: {season: string; icon: string; challenge: string; service: string}) => (
          <div class="weather-card card">
            <div class="weather-card__icon">{w.icon}</div>
            <h3 class="weather-card__season">{w.season}</h3>
            <p class="weather-card__challenge"><strong>Risque :</strong> {w.challenge}</p>
            <p class="weather-card__service"><strong>Notre solution :</strong> {w.service}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Major Employers -->
  <section class="section section--alt" id="employeurs">
    <div class="container">
      <p class="label">Entreprises & institutions</p>
      <h2 class="section-title">Employeurs Majeurs à {loc.city} que Nous Servons</h2>
      <p class="section-subtitle">Nous intervenons pour les particuliers ET les professionnels de la région.</p>
      <div class="emp-grid">
        {loc.employers.map((emp: {name: string; type: string}) => (
          <div class="emp-chip">
            <span class="emp-chip__name">{emp.name}</span>
            <span class="emp-chip__type">{emp.type}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Content -->
  <section class="section" id="local">
    <div class="container">
      <p class="label">Informations locales</p>
      <h2 class="section-title">Plombier {loc.city} : Ce que Vous Devez Savoir</h2>
      <div class="local-list">
        {loc.localContent.map((item: {title: string; text: string}) => (
          <div class="local-item card">
            <h3 class="local-item__title">{item.title}</h3>
            <p class="local-item__text">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Competitor Comparison -->
  <section class="section section--alt" id="comparaison">
    <div class="container">
      <p class="label">Comparaison</p>
      <h2 class="section-title">Pourquoi Nous Choisir plutôt qu'un Autre Plombier à {loc.city}</h2>
      <div class="comp-table-wrap">
        <table class="comp-table">
          <thead>
            <tr>
              <th>Critère</th>
              <th class="comp-table__us">Plombier Urgence</th>
              <th>Autres plombiers {loc.city}</th>
            </tr>
          </thead>
          <tbody>
            {loc.competitors.map((c: {feature: string; us: string; others: string}) => (
              <tr>
                <td class="comp-table__feature">{c.feature}</td>
                <td class="comp-table__us-val">{c.us}</td>
                <td class="comp-table__others">{c.others}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section" id="faq">
    <div class="container">
      <p class="label">Questions fréquentes</p>
      <h2 class="section-title">FAQ — Plombier {loc.city}</h2>
      <div class="faq-list">
        {loc.faqs.map((faq: {q: string; a: string}) => (
          <details class="faq-item">
            <summary class="faq-item__q">{faq.q}</summary>
            <div class="faq-item__a">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner title={`Plombier ${loc.city} — Intervention en ${loc.responseTime}`} subtitle={`Tarifs clairs 2025, prix fixe, pas de surprise. ☎ 0470 12 34 56`} />

</Layout>

<style>
  /* Breadcrumb */
  .bc-section{padding:var(--space-lg) 0 0}.bc{display:flex;align-items:center;gap:var(--space-sm);font-size:var(--font-size-sm);color:var(--color-text-dim);flex-wrap:wrap}.bc a{color:var(--color-text-muted);transition:color var(--transition-fast)}.bc a:hover{color:var(--color-accent)}.bc--current{color:var(--color-text);font-weight:600}

  .label{font-size:var(--font-size-sm);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-accent);margin-bottom:var(--space-sm)}
  .section--alt{background:var(--color-bg-alt)}

  /* Hero */
  .loc-hero{position:relative;padding:var(--space-3xl) 0 var(--space-2xl);overflow:hidden}
  .loc-hero__bg{position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(80,160,226,.08) 0%,transparent 50%);pointer-events:none}
  .loc-hero__inner{position:relative;max-width:700px}
  .loc-hero__badge{display:inline-block;background:var(--color-accent-glow);color:var(--color-accent);padding:.4rem 1rem;border-radius:999px;font-size:var(--font-size-sm);font-weight:700;margin-bottom:var(--space-lg)}
  .loc-hero__title{font-size:var(--font-size-4xl);font-weight:900;line-height:1.15;margin-bottom:var(--space-lg)}
  .loc-hero__sub{font-size:var(--font-size-lg);color:var(--color-text-muted);line-height:1.7;margin-bottom:var(--space-xl)}
  .loc-hero__chips{display:flex;flex-wrap:wrap;gap:var(--space-sm);margin-bottom:var(--space-xl)}
  .chip{background:var(--color-surface);border:1px solid var(--color-border);padding:.4rem 1rem;border-radius:999px;font-size:var(--font-size-sm);font-weight:500;color:var(--color-text-muted)}
  .chip--accent{background:rgba(80,160,226,.08);border-color:rgba(80,160,226,.2);color:var(--color-accent);font-weight:700}
  .loc-hero__actions{display:flex;gap:var(--space-md);flex-wrap:wrap}

  /* Neighborhoods */
  .nb-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--space-lg);margin-top:var(--space-xl)}
  .nb-card{padding:var(--space-xl)}
  .nb-card__header{display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--space-sm);gap:var(--space-md)}
  .nb-card__title{font-size:var(--font-size-base);font-weight:700}
  .nb-card__time{background:rgba(80,160,226,.08);color:var(--color-accent);padding:.25rem .7rem;border-radius:999px;font-size:var(--font-size-xs);font-weight:700;white-space:nowrap}
  .nb-card__text{color:var(--color-text-muted);font-size:var(--font-size-sm);line-height:1.7}

  /* Directions */
  .dir-list{display:flex;flex-direction:column;gap:var(--space-md);margin-top:var(--space-xl);max-width:700px}
  .dir-item{display:flex;gap:var(--space-xl);padding:var(--space-lg);background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg)}
  .dir-item__from{display:flex;align-items:center;gap:var(--space-sm);min-width:220px}
  .dir-item__icon{font-size:1.2rem}
  .dir-item__time{background:rgba(80,160,226,.08);color:var(--color-accent);padding:.2rem .6rem;border-radius:999px;font-size:var(--font-size-xs);font-weight:700;display:inline-block;margin-bottom:var(--space-xs)}
  .dir-item__route{color:var(--color-text-muted);font-size:var(--font-size-sm);line-height:1.6}

  /* Weather */
  .weather-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-lg);margin-top:var(--space-xl)}
  .weather-card{padding:var(--space-xl);text-align:center}
  .weather-card__icon{font-size:2.5rem;margin-bottom:var(--space-sm)}
  .weather-card__season{font-size:var(--font-size-base);font-weight:700;margin-bottom:var(--space-md);color:var(--color-accent)}
  .weather-card__challenge,.weather-card__service{font-size:var(--font-size-sm);color:var(--color-text-muted);line-height:1.6;margin-bottom:var(--space-sm);text-align:left}

  /* Employers */
  .emp-grid{display:flex;flex-wrap:wrap;gap:var(--space-md);margin-top:var(--space-xl);justify-content:center}
  .emp-chip{display:flex;flex-direction:column;align-items:center;gap:4px;background:var(--color-surface);border:1px solid var(--color-border);padding:var(--space-lg) var(--space-xl);border-radius:var(--radius-lg);min-width:200px;text-align:center}
  .emp-chip__name{font-weight:700;font-size:var(--font-size-sm)}
  .emp-chip__type{font-size:var(--font-size-xs);color:var(--color-text-dim);text-transform:uppercase;letter-spacing:.05em}

  /* Local */
  .local-list{display:flex;flex-direction:column;gap:var(--space-lg);margin-top:var(--space-xl)}
  .local-item{padding:var(--space-xl)}
  .local-item__title{font-size:var(--font-size-lg);font-weight:700;margin-bottom:var(--space-sm)}
  .local-item__text{color:var(--color-text-muted);font-size:var(--font-size-sm);line-height:1.8}

  /* Comparison table */
  .comp-table-wrap{overflow-x:auto;margin-top:var(--space-xl);border-radius:var(--radius-lg);border:1px solid var(--color-border)}
  .comp-table{width:100%;border-collapse:collapse;font-size:var(--font-size-sm)}
  .comp-table th{background:var(--color-surface);padding:.9rem 1.2rem;text-align:left;font-weight:700;border-bottom:2px solid var(--color-border)}
  .comp-table td{padding:.8rem 1.2rem;border-bottom:1px solid rgba(255,255,255,.04)}
  .comp-table__us{color:var(--color-accent);background:rgba(80,160,226,.05)}
  .comp-table__feature{font-weight:600}
  .comp-table__us-val{color:var(--color-accent);font-weight:600;background:rgba(80,160,226,.03)}
  .comp-table__others{color:var(--color-text-dim)}

  /* FAQ */
  .faq-list{display:flex;flex-direction:column;gap:var(--space-sm);max-width:760px;margin:var(--space-xl) auto 0}
  .faq-item{background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);overflow:hidden;transition:border-color var(--transition-fast)}
  .faq-item[open]{border-color:var(--color-accent)}
  .faq-item__q{padding:var(--space-lg) var(--space-xl);font-weight:700;cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between}
  .faq-item__q::after{content:'+';font-size:1.4rem;color:var(--color-accent);font-weight:300}
  .faq-item[open] .faq-item__q::after{content:'−'}
  .faq-item__q::-webkit-details-marker{display:none}
  .faq-item__a{padding:0 var(--space-xl) var(--space-lg);color:var(--color-text-muted);font-size:var(--font-size-sm);line-height:1.8}

  @media(max-width:1024px){
    .weather-grid{grid-template-columns:repeat(2,1fr)}
    .dir-item{flex-direction:column;gap:var(--space-sm)}
    .dir-item__from{min-width:auto}
  }
  @media(max-width:768px){
    .nb-grid{grid-template-columns:1fr}
    .weather-grid{grid-template-columns:1fr}
    .emp-grid{flex-direction:column}
    .emp-chip{min-width:auto}
  }
</style>
