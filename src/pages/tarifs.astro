---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';

const faqs = [
  {
    q: "Quel est le prix d'un débouchage d'évier ou de lavabo en Belgique ?",
    a: "Le débouchage d'un évier ou lavabo coûte entre 60€ et 120€ TTC chez Plombier Urgence. Ce tarif comprend le déplacement, le diagnostic, et l'intervention. Pour un débouchage haute pression (hydrocurage), comptez entre 120€ et 220€. Tarif fixe communiqué avant toute intervention."
  },
  {
    q: "Y a-t-il des frais supplémentaires pour une intervention en urgence la nuit ?",
    a: "Un supplément de 30% à 50% s'applique entre 20h et 7h, ainsi que les week-ends et jours fériés belges. Ce montant est toujours confirmé par téléphone avant l'intervention. Exemple : une intervention à 60€ de jour revient à environ 78€–90€ de nuit."
  },
  {
    q: "La TVA est-elle incluse dans les tarifs affichés ?",
    a: "Tous les tarifs affichés sur plombierurgence.be sont exprimés TTC (TVA 21% incluse pour les entreprises, 6% TVA réduite possible pour les particuliers sur certains travaux dans les habitations de plus de 10 ans, selon la réglementation belge en vigueur)."
  },
  {
    q: "Quel est le tarif pour un dépannage chaudière en Belgique ?",
    a: "Le dépannage chaudière démarre à 150€ TTC chez Plombier Urgence. Ce tarif comprend le diagnostic, la main d'œuvre, et les petites pièces courantes. Pour les pannes complexes nécessitant le remplacement de pièces importantes, un devis détaillé est fourni sur place avant toute intervention."
  },
  {
    q: "Plombier Urgence intervient-il dans toute la Belgique au même tarif ?",
    a: "Oui, nos tarifs sont identiques dans toutes nos zones d'intervention : Bruxelles et les 19 communes, Liège, Namur, Charleroi, Mons et leurs environs. Il n'y a pas de supplément de déplacement dans un rayon de 50 km. Seul un supplément nuit ou week-end peut s'appliquer."
  }
];
---

<Layout 
  title="Tarifs Plombier Belgique 2025 — Prix Débouchage, Fuite & Chaudière | Plombier Urgence" 
  description="Tarifs plombier Belgique 2025 : débouchage dès 60€, fuite dès 95€, chaudière dès 150€. Prix fixes. Devis gratuit. ☎ 0465 68 51 58"
  {faqs}
>

  <section class="bc-section">
    <div class="container">
      <nav class="bc">
        <a href="/">Accueil</a><span>›</span>
        <span class="bc--current">Tarifs</span>
      </nav>
    </div>
  </section>

  <section class="tarif-hero">
    <div class="tarif-hero__bg"></div>
    <div class="container tarif-hero__inner">
      <p class="label">Nos Tarifs 2025</p>
      <h1 class="tarif-hero__title">Tarifs Plombier Belgique 2025 : <span class="text-accent">Prix Fixes, Sans Surprise</span></h1>
      <p class="tarif-hero__text"><strong>Voici nos tarifs exacts.</strong> Communiqués avant toute intervention. Pas de devis surprise à la fin. Débouchage dès <strong>60€ TTC</strong> &bull; Fuite d'eau dès <strong>95€ TTC</strong> &bull; Chaudière dès <strong>150€ TTC</strong>. Selon la <a href="https://www.confederationconstruction.be" target="_blank" rel="noopener noreferrer">Confédération Construction Belge</a>, le tarif horaire moyen d'un plombier agréé en Belgique est de 90€ à 130€ HTVA (2024). Nos forfaits fixes sont souvent <strong>20 à 35% moins chers</strong> qu'une facturation à l'heure.</p>
      
      <blockquote class="expert-quote-box" style="margin-top:2rem;text-align:left;background:rgba(255,255,255,0.05);padding:1.5rem;border-left:4px solid var(--color-accent);border-radius:0 var(--radius-lg) var(--radius-lg) 0;">
        <p style="font-style:italic;font-size:1.1rem;margin-bottom:0.5rem;">"La transparence des tarifs avant intervention est une exigence légale en Belgique depuis la loi du 21 décembre 2013 sur les services."</p>
        <footer style="font-size:0.9rem;color:var(--color-text-muted);font-weight:600;">— <cite>SPF Économie, Direction générale Inspection économique</cite></footer>
      </blockquote>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title" style="text-align:center;">Grille Tarifaire Indicative</h2>
      <p class="section-sub">Les prix ci-dessous sont des fourchettes indicatives. Un devis précis et gratuit est fourni sur place avant toute intervention.</p>

      <div class="tarif-grid">
        <div class="tarif-card card">
          <div class="tarif-card__icon">🚿</div>
          <h3>Débouchage</h3>
          <div class="tarif-card__items">
            <div class="tarif-line"><span>Débouchage évier / lavabo</span><span class="tarif-price">60€ – 120€</span></div>
            <div class="tarif-line"><span>Débouchage WC</span><span class="tarif-price">60€ – 150€</span></div>
            <div class="tarif-line"><span>Débouchage canalisation principale</span><span class="tarif-price">150€ – 350€</span></div>
            <div class="tarif-line"><span>Curage haute pression</span><span class="tarif-price">200€ – 500€</span></div>
            <div class="tarif-line"><span>Détartrage canalisation</span><span class="tarif-price">120€ – 250€</span></div>
            <div class="tarif-line"><span>Inspection caméra</span><span class="tarif-price">100€ – 200€</span></div>
          </div>
        </div>

        <div class="tarif-card card">
          <div class="tarif-card__icon">🔍</div>
          <h3>Fuites & Détection</h3>
          <div class="tarif-card__items">
            <div class="tarif-line"><span>Réparation fuite robinet</span><span class="tarif-price">60€ – 120€</span></div>
            <div class="tarif-line"><span>Réparation fuite tuyau</span><span class="tarif-price">100€ – 250€</span></div>
            <div class="tarif-line"><span>Détection fuite (thermique)</span><span class="tarif-price">150€ – 300€</span></div>
            <div class="tarif-line"><span>Remplacement tuyauterie (ml)</span><span class="tarif-price">60€ – 150€/ml</span></div>
          </div>
        </div>

        <div class="tarif-card card">
          <div class="tarif-card__icon">🔥</div>
          <h3>Chauffe-eau & Chaudière</h3>
          <div class="tarif-card__items">
            <div class="tarif-line"><span>Installation chauffe-eau électrique</span><span class="tarif-price">300€ – 500€</span></div>
            <div class="tarif-line"><span>Installation chauffe-eau gaz</span><span class="tarif-price">400€ – 800€</span></div>
            <div class="tarif-line"><span>Remplacement chauffe-eau</span><span class="tarif-price">400€ – 900€</span></div>
            <div class="tarif-line"><span>Entretien chaudière annuel</span><span class="tarif-price">100€ – 180€</span></div>
            <div class="tarif-line"><span>Dépannage chaudière</span><span class="tarif-price">120€ – 300€</span></div>
          </div>
        </div>

        <div class="tarif-card card">
          <div class="tarif-card__icon">🛁</div>
          <h3>Rénovation & Installation</h3>
          <div class="tarif-card__items">
            <div class="tarif-line"><span>Installation WC</span><span class="tarif-price">150€ – 400€</span></div>
            <div class="tarif-line"><span>Pose robinetterie</span><span class="tarif-price">60€ – 200€</span></div>
            <div class="tarif-line"><span>Installation douche</span><span class="tarif-price">300€ – 800€</span></div>
            <div class="tarif-line"><span>Remplacement baignoire</span><span class="tarif-price">500€ – 1 200€</span></div>
            <div class="tarif-line"><span>Rénovation salle de bain complète</span><span class="tarif-price">5 000€ – 15 000€</span></div>
            <div class="tarif-line"><span>Installation adoucisseur eau</span><span class="tarif-price">800€ – 1 500€</span></div>
          </div>
        </div>
      </div>

      <div class="tarif-note card">
        <h3>💡 Bon à savoir</h3>
        <ul>
          <li><strong>Devis gratuit</strong> : un technicien évalue sur place et vous fournit un prix fixe avant intervention.</li>
          <li><strong>Pas de frais cachés</strong> : le montant annoncé inclut déplacement, main d'œuvre et pièces (sauf remplacement majeur).</li>
          <li><strong>Même prix nuit & week-end</strong> : pas de majoration abusive pour les urgences.</li>
          <li><strong>Garantie 2 ans</strong> : toutes nos interventions sont couvertes 2 ans pièces et main d'œuvre.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ tarifs -->
  <section class="section faq-section">
    <div class="container faq-container">
      <p class="label">Questions Fréquentes</p>
      <h2 class="section-title">FAQ Prix et Tarifs Plombier</h2>
      <div class="faq-list">
        <details class="faq-item card">
          <summary class="faq-q">Quel est le prix d'un plombier à Bruxelles ?</summary>
          <p class="faq-a">Le tarif d'un plombier à Bruxelles dépend du type d'intervention. Un dépannage simple coûte entre 60€ et 150€. Des travaux plus complexes (remplacement tuyauterie, installation) peuvent aller de 200€ à 1 000€+. Nous fournissons toujours un devis gratuit avant de commencer.</p>
        </details>
        <details class="faq-item card">
          <summary class="faq-q">Existe-t-il un plombier pas cher à Bruxelles ?</summary>
          <p class="faq-a">Oui, chez Plombier Urgence nous pratiquons des tarifs compétitifs et transparents. Notre priorité est un service de qualité à un prix juste. Nous ne pratiquons pas de tarifs gonflés pour les urgences nocturnes.</p>
        </details>
        <details class="faq-item card">
          <summary class="faq-q">Combien coûte le débouchage d'une canalisation à Bruxelles ?</summary>
          <p class="faq-a">Le prix d'un débouchage de canalisation à Bruxelles varie de 60€ pour un débouchage simple (évier, WC) à 350€ pour une canalisation principale nécessitant un hydrocurage. Devis gratuit sur place.</p>
        </details>
        <details class="faq-item card">
          <summary class="faq-q">Combien coûte l'installation d'un chauffe-eau à Bruxelles ?</summary>
          <p class="faq-a">Le prix d'installation d'un chauffe-eau à Bruxelles dépend du modèle : 300€ à 500€ pour un modèle électrique, 400€ à 800€ pour un modèle au gaz, hors coût de l'appareil. Nous installons toutes les marques.</p>
        </details>
        <details class="faq-item card">
          <summary class="faq-q">Y a-t-il un plombier pas cher à Charleroi ?</summary>
          <p class="faq-a">Oui, nos tarifs sont les mêmes dans toutes nos zones d'intervention, y compris Charleroi. Nous proposons un service professionnel à prix compétitif avec devis gratuit.</p>
        </details>
        <details class="faq-item card">
          <summary class="faq-q">Le devis est-il vraiment gratuit ?</summary>
          <p class="faq-a">Oui, 100% gratuit et sans engagement. Le technicien se déplace, évalue les travaux et vous remet un devis détaillé. Vous décidez ensuite en toute liberté.</p>
        </details>
      </div>
    </div>
  </section>

  <CTABanner title="Besoin d'un devis précis ?" subtitle="Appelez-nous ou remplissez notre formulaire pour un devis gratuit et personnalisé." />
</Layout>

<style>
  .bc-section{padding:var(--space-lg) 0 0}
  .bc{display:flex;align-items:center;gap:var(--space-sm);font-size:var(--font-size-sm);color:var(--color-text-dim);flex-wrap:wrap}
  .bc a{color:var(--color-text-muted);transition:color var(--transition-fast)}
  .bc a:hover{color:var(--color-accent)}
  .bc--current{color:var(--color-text);font-weight:600}
  .label{font-size:var(--font-size-sm);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-accent);margin-bottom:var(--space-sm)}

  .tarif-hero{position:relative;padding:var(--space-3xl) 0 var(--space-2xl);overflow:hidden}
  .tarif-hero__bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(80,160,226,.06) 0%,transparent 50%);pointer-events:none}
  .tarif-hero__inner{position:relative;max-width:700px}
  .tarif-hero__title{font-size:var(--font-size-4xl);font-weight:900;line-height:1.15;margin-bottom:var(--space-lg)}
  .tarif-hero__text{font-size:var(--font-size-lg);color:var(--color-text-muted);line-height:1.7}

  .section-sub{text-align:center;color:var(--color-text-muted);max-width:600px;margin:0 auto var(--space-2xl);line-height:1.7}

  .tarif-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--space-xl)}
  .tarif-card{padding:var(--space-xl)}
  .tarif-card__icon{font-size:1.8rem;margin-bottom:var(--space-md)}
  .tarif-card h3{font-size:var(--font-size-lg);font-weight:700;margin-bottom:var(--space-lg);padding-bottom:var(--space-md);border-bottom:1px solid var(--color-border)}
  .tarif-card__items{display:flex;flex-direction:column;gap:var(--space-sm)}
  .tarif-line{display:flex;justify-content:space-between;align-items:center;padding:var(--space-sm) 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:var(--font-size-sm)}
  .tarif-line span:first-child{color:var(--color-text-muted)}
  .tarif-price{font-weight:700;color:var(--color-accent);white-space:nowrap}

  .tarif-note{padding:var(--space-xl);margin-top:var(--space-2xl)}
  .tarif-note h3{font-size:var(--font-size-lg);font-weight:700;margin-bottom:var(--space-md)}
  .tarif-note ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:var(--space-sm)}
  .tarif-note li{color:var(--color-text-muted);font-size:var(--font-size-sm);line-height:1.7;padding-left:1rem;position:relative}
  .tarif-note li::before{content:'✓';position:absolute;left:0;color:var(--color-accent)}

  .faq-section{background:var(--color-bg-alt)}
  .faq-container{max-width:800px}
  .faq-list{display:flex;flex-direction:column;gap:var(--space-md)}
  .faq-item{padding:var(--space-lg) var(--space-xl);cursor:pointer}
  .faq-q{font-weight:700;font-size:var(--font-size-base);list-style:none;display:flex;justify-content:space-between;align-items:center}
  .faq-q::after{content:'＋';color:var(--color-accent);font-size:1.2rem}
  .faq-item[open] .faq-q::after{content:'−'}
  .faq-a{margin-top:var(--space-md);color:var(--color-text-muted);line-height:1.7;font-size:var(--font-size-sm)}

  @media(max-width:768px){.tarif-grid{grid-template-columns:1fr}}
</style>
