---
import Layout from '../../layouts/Layout.astro';
import CTABanner from '../../components/CTABanner.astro';
import { longTailFaqs } from '../../data/long-tail-faqs';
import { servicePages } from '../../data/service-details';
import { slugify } from '../../data/communes';

export function getStaticPaths() {
  return longTailFaqs.map(faq => ({
    params: { slug: faq.slug },
    props: { faq },
  }));
}

const { faq } = Astro.props;

// Build Service schema links
const relatedServiceData = servicePages.filter(s => faq.relatedServices.includes(s.slug));

// Build FAQPage schema
const faqPageSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.directAnswer
      }
    },
    ...faq.subFaqs.map(sf => ({
      "@type": "Question",
      "name": sf.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": sf.a
      }
    }))
  ]
};

// Breadcrumb schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://www.plombierurgence.be/" },
    { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://www.plombierurgence.be/faq/" },
    { "@type": "ListItem", "position": 3, "name": faq.question, "item": `https://www.plombierurgence.be/faq/${faq.slug}/` }
  ]
};

const extraSchemas = [faqPageSchema, breadcrumbSchema];
---

<Layout
  title={faq.metaTitle}
  description={faq.metaDescription}
  faqs={faq.subFaqs}
  extraSchemas={extraSchemas}
>

  <!-- Breadcrumb -->
  <section class="bc-section">
    <div class="container">
      <nav class="bc">
        <a href="/">Accueil</a><span>›</span>
        <a href="/faq/">FAQ</a><span>›</span>
        <span class="bc--current">{faq.question}</span>
      </nav>
    </div>
  </section>

  <!-- Hero / Main Question -->
  <section class="faq-page-hero">
    <div class="faq-page-hero__bg"></div>
    <div class="container faq-page-hero__inner">
      <p class="label">FAQ Plomberie</p>
      <h1 class="faq-page-hero__title">{faq.question}</h1>
      <div class="faq-page-hero__answer">
        <p>{faq.directAnswer}</p>
      </div>
      <div class="faq-page-hero__actions">
        <a href="tel:0465685158" class="btn btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
          0465 68 51 58
        </a>
        <a href="https://wa.me/32465685158" class="btn btn-outline btn-lg" target="_blank" rel="noopener noreferrer">WhatsApp — Envoyez une photo</a>
      </div>
    </div>
  </section>

  <!-- Body Content -->
  <section class="section" id="details">
    <div class="container">
      <div class="faq-page-body" set:html={faq.bodyContent} />
    </div>
  </section>

  <!-- Sub-FAQs -->
  <section class="section section--alt" id="questions-liees">
    <div class="container">
      <p class="label">Questions liées</p>
      <h2 class="section-title">Questions fréquentes sur ce sujet</h2>
      <div class="faq-list">
        {faq.subFaqs.map(sf => (
          <details class="faq-item">
            <summary class="faq-item__q">{sf.q}</summary>
            <div class="faq-item__a">{sf.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  {relatedServiceData.length > 0 && (
    <section class="section" id="services-lies">
      <div class="container">
        <p class="label">Services liés</p>
        <h2 class="section-title">Nos services pour résoudre ce problème</h2>
        <div class="related-grid">
          {relatedServiceData.map(r => (
            <a href={`/service/${r.slug}/`} class="related-card card">
              <div class="related-card__icon">{r.icon}</div>
              <h3 class="related-card__title">{r.title}</h3>
              <p class="related-card__price">Dès {r.priceFrom}</p>
              <span class="related-card__link">En savoir plus →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Commune Cross-links -->
  <section class="section section--alt" id="communes">
    <div class="container">
      <p class="label">Zones d'intervention</p>
      <h2 class="section-title">Nous intervenons près de chez vous</h2>
      <div class="zones-chips">
        {faq.relatedCommunes.map(name => {
          const slug = name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
          let link = `/zones/`;
          if (name === 'Bruxelles') link = `/urgence/bruxelles/`;
          else if (name === 'Liège') link = `/urgence/liege/`;
          else if (name === 'Namur') link = `/urgence/namur/`;
          else if (name === 'Charleroi') link = `/urgence/charleroi/`;
          else if (name === 'Wavre') link = `/urgence/wavre/`;
          else if (name === 'Mons') link = `/zones/hainaut/mons/`;
          else if (name === 'Waterloo') link = `/zones/brabant-wallon/waterloo/`;
          else link = `/zones/`;
          return <a href={link} class="zone-chip">Plombier {name}</a>;
        })}
      </div>
      <div style="text-align:center;margin-top:var(--space-lg);">
        <a href="/zones/" class="btn btn-outline">Voir toutes nos zones d'intervention →</a>
      </div>
    </div>
  </section>

  <!-- Other FAQ Pages -->
  <section class="section" id="autres-questions">
    <div class="container">
      <p class="label">Autres questions fréquentes</p>
      <h2 class="section-title">D'autres questions que vous pourriez poser</h2>
      <div class="other-faqs-grid">
        {longTailFaqs.filter(f => f.slug !== faq.slug).slice(0, 4).map(f => (
          <a href={`/faq/${f.slug}/`} class="other-faq-card card">
            <h3 class="other-faq-card__title">{f.question}</h3>
            <span class="other-faq-card__link">Lire la réponse →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner title="Besoin d'une intervention ?" subtitle="Appelez-nous 24h/24 — Tarifs fixes, intervention en 30 min." />

</Layout>

<style>
  /* Breadcrumb */
  .bc-section{padding:var(--space-lg) 0 0}.bc{display:flex;align-items:center;gap:var(--space-sm);font-size:var(--font-size-sm);color:var(--color-text-dim);flex-wrap:wrap}.bc a{color:var(--color-text-muted);transition:color var(--transition-fast)}.bc a:hover{color:var(--color-accent)}.bc--current{color:var(--color-text);font-weight:600}

  .label{font-size:var(--font-size-sm);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-accent);margin-bottom:var(--space-sm)}
  .section--alt{background:var(--color-bg-alt)}

  /* Hero */
  .faq-page-hero {
    position: relative;
    padding: var(--space-3xl) 0 var(--space-2xl);
    overflow: hidden;
  }
  .faq-page-hero__bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(80,160,226,.08) 0%, transparent 50%);
    pointer-events: none;
  }
  .faq-page-hero__inner {
    position: relative;
    max-width: 800px;
  }
  .faq-page-hero__title {
    font-size: var(--font-size-3xl);
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: var(--space-xl);
  }
  .faq-page-hero__answer {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-xl);
  }
  .faq-page-hero__answer p {
    font-size: var(--font-size-lg);
    line-height: 1.8;
    color: var(--color-text);
    margin: 0;
    font-weight: 500;
  }
  .faq-page-hero__actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  /* Body */
  .faq-page-body {
    max-width: 760px;
    margin: 0 auto;
  }
  .faq-page-body :global(h3) {
    font-size: var(--font-size-xl);
    font-weight: 800;
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }
  .faq-page-body :global(p) {
    color: var(--color-text-muted);
    font-size: var(--font-size-base);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }
  .faq-page-body :global(ul) {
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-lg);
  }
  .faq-page-body :global(li) {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.7;
  }
  .faq-page-body :global(li::before) {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }
  .faq-page-body :global(strong) {
    color: var(--color-text);
  }

  /* FAQ accordion */
  .faq-list{display:flex;flex-direction:column;gap:var(--space-sm);max-width:760px;margin:var(--space-xl) auto 0}
  .faq-item{background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg);overflow:hidden;transition:border-color var(--transition-fast)}
  .faq-item[open]{border-color:var(--color-accent)}
  .faq-item__q{padding:var(--space-lg) var(--space-xl);font-weight:700;cursor:pointer;list-style:none;display:flex;align-items:center;justify-content:space-between}
  .faq-item__q::after{content:'+';font-size:1.4rem;color:var(--color-accent);font-weight:300;transition:transform var(--transition-fast)}
  .faq-item[open] .faq-item__q::after{content:'−'}
  .faq-item__q::-webkit-details-marker{display:none}
  .faq-item__a{padding:0 var(--space-xl) var(--space-lg);color:var(--color-text-muted);font-size:var(--font-size-sm);line-height:1.8}

  /* Related services */
  .related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:var(--space-lg);margin-top:var(--space-xl)}
  .related-card{padding:var(--space-xl);text-align:center;text-decoration:none;transition:all var(--transition-fast)}
  .related-card:hover{border-color:var(--color-accent);transform:translateY(-2px)}
  .related-card__icon{font-size:2rem;margin-bottom:var(--space-sm)}
  .related-card__title{font-size:var(--font-size-lg);font-weight:700;color:var(--color-text);margin-bottom:var(--space-xs)}
  .related-card__price{color:var(--color-accent);font-weight:700;font-size:var(--font-size-sm);margin-bottom:var(--space-sm)}
  .related-card__link{color:var(--color-accent);font-size:var(--font-size-sm);font-weight:600}

  /* Zone chips */
  .zones-chips{display:flex;flex-wrap:wrap;gap:var(--space-sm);justify-content:center;margin-top:var(--space-xl)}
  .zone-chip{background:var(--color-surface);border:1px solid var(--color-border);padding:.5rem 1.25rem;border-radius:999px;font-size:var(--font-size-sm);font-weight:500;color:var(--color-text-muted);text-decoration:none;transition:all var(--transition-fast)}
  .zone-chip:hover{border-color:var(--color-accent);color:var(--color-accent);background:var(--color-accent-glow)}

  /* Other FAQ cards */
  .other-faqs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:var(--space-lg);margin-top:var(--space-xl)}
  .other-faq-card{padding:var(--space-xl);text-decoration:none;transition:all var(--transition-fast)}
  .other-faq-card:hover{border-color:var(--color-accent);transform:translateY(-2px)}
  .other-faq-card__title{font-size:var(--font-size-base);font-weight:700;color:var(--color-text);margin-bottom:var(--space-sm);line-height:1.4}
  .other-faq-card__link{color:var(--color-accent);font-size:var(--font-size-sm);font-weight:600}

  @media(max-width:768px){
    .other-faqs-grid{grid-template-columns:1fr}
    .related-grid{grid-template-columns:1fr}
  }
</style>
