---
import Layout from '../layouts/Layout.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Layout title="Nos Services Plomberie Belgique | Urgence & Rénovation" description="Découvrez nos services de plomberie : débouchage, recherche de fuite, dépannage chaudière, rénovation salle de bain et plus. Intervention rapide en Belgique." preloadHero={true}>

  <!-- Hero -->
  <section class="services-hero">
    <div class="services-hero__bg"></div>
    <div class="container services-hero__inner">
      <p class="section-label">Nos Services</p>
      <h1 class="services-hero__title">Solutions de Plomberie <span class="text-accent">Rapides et Professionnelles</span></h1>
      <p class="services-hero__subtitle">Une équipe d'experts agréés prête à intervenir partout en Belgique pour vos urgences et projets de rénovation. Transparence totale sur les prix.</p>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="section">
    <div class="container services-list">

      <div class="service-detail" id="debouchage">
        <div class="service-detail__image-wrap">
          <img src="/images/service-debouchage.webp" alt="Débouchage de canalisations haute pression et réparation de tuyaux bouchés en Belgique" loading="lazy" decoding="async" width="600" height="400" />
        </div>
        <div class="service-detail__content">
          <div class="service-detail__header">
            <div class="service-detail__icon">🚿</div>
            <h2 class="service-detail__title">Débouchage Canalisations</h2>
          </div>
          <p class="service-detail__text">WC, évier, douche ou baignoire bouchés ? Nous intervenons avec du matériel haute pression pour un débouchage immédiat. Inspection caméra incluse pour garantir un résultat durable.</p>
          <ul class="service-detail__features">
            <li>✓ Intervention haute pression professionnelle</li>
            <li>✓ Inspection caméra incluse</li>
            <li>✓ WC, éviers, douches et égouts</li>
            <li>✓ Résultat garanti 6 mois</li>
          </ul>
          <a href="/service/debouchage-canalisation/" class="btn btn-primary">Voir le détail & tarifs →</a>
        </div>
      </div>

      <div class="service-detail" id="fuite">
        <div class="service-detail__image-wrap">
          <img src="/images/service-fuite.webp" alt="Recherche de fuite d'eau sans casse et réparation d'urgence par un plombier certifié" loading="lazy" decoding="async" width="600" height="400" />
        </div>
        <div class="service-detail__content">
          <div class="service-detail__header">
            <div class="service-detail__icon">🔍</div>
            <h2 class="service-detail__title">Détection & Recherche de Fuite</h2>
          </div>
          <p class="service-detail__text">Utilisation de technologies non invasives (thermique, acoustique) pour localiser précisément les fuites sans casser vos murs ni vos sols. Réparation rapide garantie.</p>
          <ul class="service-detail__features">
            <li>✓ Caméra thermique de précision</li>
            <li>✓ Détection acoustique avancée</li>
            <li>✓ Sans destruction ni casse</li>
            <li>✓ Rapport détaillé fourni</li>
          </ul>
          <a href="/service/recherche-fuite/" class="btn btn-primary">Voir le détail & tarifs →</a>
        </div>
      </div>

      <div class="service-detail" id="chaudiere">
        <div class="service-detail__image-wrap">
          <img src="/images/service-chaudiere.webp" alt="Dépannage de chaudière gaz et mazout, entretien et réparation chauffage en urgence" loading="lazy" decoding="async" width="600" height="400" />
        </div>
        <div class="service-detail__content">
          <div class="service-detail__header">
            <div class="service-detail__icon">🔥</div>
            <h2 class="service-detail__title">Dépannage & Installation Chaudière</h2>
          </div>
          <p class="service-detail__text">Pose, entretien et dépannage de chaudières gaz et mazout. Nos experts vous conseillent pour optimiser votre consommation énergétique. Intervention sur toutes les marques.</p>
          <ul class="service-detail__features">
            <li>✓ Toutes marques et modèles</li>
            <li>✓ Entretien annuel obligatoire</li>
            <li>✓ Chauffagistes agréés Cerga</li>
            <li>✓ Conseils en économie d'énergie</li>
          </ul>
          <a href="/service/depannage-chaudiere/" class="btn btn-primary">Voir le détail & tarifs →</a>
        </div>
      </div>

      <div class="service-detail" id="robinetterie">
        <div class="service-detail__image-wrap">
          <img src="/images/service-robinetterie.webp" alt="Réparation de robinetterie, de mitigeurs et installation sanitaire par un plombier agréé" loading="lazy" decoding="async" width="600" height="400" />
        </div>
        <div class="service-detail__content">
          <div class="service-detail__header">
            <div class="service-detail__icon">🔧</div>
            <h2 class="service-detail__title">Réparation Robinetterie & Sanitaires</h2>
          </div>
          <p class="service-detail__text">Remplacement de robinets, mitigeurs, chasse d'eau qui coule. Installation de nouveaux sanitaires. Diagnostic panne d'eau chaude, détartrage et remplacement de résistance.</p>
          <ul class="service-detail__features">
            <li>✓ Remplacement robinets et mitigeurs</li>
            <li>✓ Réparation chasse d'eau</li>
            <li>✓ Installation sanitaires neufs</li>
            <li>✓ Détartrage chauffe-eau</li>
          </ul>
          <a href="/service/reparation-robinetterie/" class="btn btn-primary">Voir le détail & tarifs →</a>
        </div>
      </div>

      <div class="service-detail" id="renovation">
        <div class="service-detail__image-wrap">
          <img src="/images/service-renovation.webp" alt="Service de rénovation de salle de bain complète et installation sanitaire à Bruxelles et environs" loading="lazy" decoding="async" width="600" height="400" />
        </div>
        <div class="service-detail__content">
          <div class="service-detail__header">
            <div class="service-detail__icon">🛁</div>
            <h2 class="service-detail__title">Rénovation Salle de Bain</h2>
          </div>
          <p class="service-detail__text">Transformation complète de votre espace bain. Installation de douches italiennes, baignoires, carrelage et robinetterie moderne. Devis gratuit et détaillé.</p>
          <ul class="service-detail__features">
            <li>✓ Douches italiennes sur mesure</li>
            <li>✓ Design moderne et fonctionnel</li>
            <li>✓ Carrelage et robinetterie</li>
            <li>✓ Devis gratuit et sans engagement</li>
          </ul>
          <a href="/service/renovation-salle-de-bain/" class="btn btn-primary">Voir le détail & tarifs →</a>
        </div>
      </div>

      <div class="service-detail" id="urgence-plomberie">
        <div class="service-detail__image-wrap">
          <img src="/images/hero-bg.webp" alt="Plombier urgence en intervention rapide pour réparation de fuites et dépannage plomberie" loading="lazy" decoding="async" width="800" height="533" />
        </div>
        <div class="service-detail__content">
          <div class="service-detail__header">
            <div class="service-detail__icon">🚨</div>
            <h2 class="service-detail__title">Urgence Plomberie</h2>
          </div>
          <p class="service-detail__text">Une urgence n'attend pas. Fuite majeure, canalisation bouchée, panne de chaudière, dégât des eaux ou inondation : notre équipe de garde intervient en 30 minutes 24h/24 et 7j/7 dans toute la Belgique.</p>
          <ul class="service-detail__features">
            <li>✓ Intervention en urgence absolue (30 min)</li>
            <li>✓ Dépannage fuites et débouchage</li>
            <li>✓ Assèchement et mise en sécurité</li>
            <li>✓ Disponibilité 24h/24 et 7j/7</li>
          </ul>
          <a href="/service/urgence-plomberie/" class="btn btn-primary">Voir le détail & tarifs →</a>
        </div>
      </div>

    </div>
  </section>

  <CTABanner />
</Layout>

<style>
  .services-hero {
    position: relative;
    padding: var(--space-4xl) 0 var(--space-2xl);
    overflow: hidden;
  }

  .services-hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(15, 23, 42, 0.95) 0%, rgba(15, 23, 42, 0.7) 100%),
      url('/images/hero-bg.webp') center/cover no-repeat;
    pointer-events: none;
    z-index: 0;
  }

  .services-hero__inner {
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .services-hero__title {
    font-size: var(--font-size-4xl);
    font-weight: 900;
    line-height: 1.15;
    margin-bottom: var(--space-lg);
    color: #fff;
  }

  .services-hero__title .text-accent {
    color: var(--color-accent);
  }

  .services-hero__subtitle {
    font-size: var(--font-size-lg);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
  }

  .section-label {
    font-size: var(--font-size-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .services-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .service-detail {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all var(--transition-base);
  }

  .service-detail:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 30px rgba(80,160,226,0.08);
  }
  
  .service-detail__image-wrap {
    width: 100%;
    height: 100%;
    min-height: 300px;
    overflow: hidden;
  }
  
  .service-detail__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  
  .service-detail:hover .service-detail__image-wrap img {
    transform: scale(1.05);
  }

  .service-detail__content {
    padding: var(--space-2xl);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .service-detail__header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .service-detail__icon {
    font-size: 2rem;
    width: 56px;
    height: 56px;
    min-width: 56px;
    background: var(--color-accent-glow);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-detail__title {
    font-size: var(--font-size-2xl);
    font-weight: 800;
    margin: 0;
  }

  .service-detail__text {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .service-detail__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .service-detail__features li {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  @media (max-width: 900px) {
    .service-detail {
      grid-template-columns: 1fr;
    }
    
    .service-detail__image-wrap {
      min-height: 200px;
    }

    .service-detail__content {
      padding: var(--space-lg);
    }
    
    .service-detail__title {
      font-size: var(--font-size-xl);
    }

    .service-detail__features {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
      margin-bottom: var(--space-lg);
    }
    
    .services-hero {
      padding: var(--space-2xl) 0 var(--space-xl);
    }
    
    .services-hero__title {
      font-size: var(--font-size-3xl);
    }
  }
</style>
