---
/**
 * Contact form using FormSubmit.co
 * Embeddable on any page — sends to contact@plombierurgence.be
 * Redirects to /thank-you/ after submission
 */
---

<section class="contact-section" id="contact-form">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="label">Contactez-nous</p>
        <h2 class="contact-info__title">Demandez un <span class="text-accent">Devis Gratuit</span></h2>
        <p class="contact-info__text">Réponse en moins de 15 minutes. Devis gratuit, sans engagement.</p>

        <div class="contact-info__items">
          <a href="tel:0465685158" class="contact-info__item">
            <span class="contact-info__icon">📞</span>
            <div>
              <strong>Appeler maintenant</strong>
              <span>0465 68 51 58</span>
            </div>
          </a>
          <a href="https://wa.me/32470123456" target="_blank" rel="noopener noreferrer" class="contact-info__item">
            <span class="contact-info__icon">💬</span>
            <div>
              <strong>WhatsApp</strong>
              <span>Envoyez une photo du problème</span>
            </div>
          </a>
          <div class="contact-info__item">
            <span class="contact-info__icon">⚡</span>
            <div>
              <strong>Intervention en 30 min</strong>
              <span>24h/24 — 7j/7</span>
            </div>
          </div>
        </div>

        <!-- Trust badges -->
        <div class="contact-trust">
          <div class="trust-badge">
            <span class="trust-badge__icon">🏆</span>
            <span>15+ ans d'expérience</span>
          </div>
          <div class="trust-badge">
            <span class="trust-badge__icon">✅</span>
            <span>Certifié & agréé</span>
          </div>
          <div class="trust-badge">
            <span class="trust-badge__icon">🛡️</span>
            <span>Garantie 2 ans</span>
          </div>
          <div class="trust-badge">
            <span class="trust-badge__icon">⭐</span>
            <span>4.9/5 — 500+ avis</span>
          </div>
        </div>
      </div>

      <form
        action="https://formsubmit.co/contact@plombierurgence.be"
        method="POST"
        class="contact-form card"
      >
        <!-- FormSubmit config -->
        <input type="hidden" name="_next" value="https://plombierurgence.be/thank-you/">
        <input type="hidden" name="_subject" value="Nouveau devis — Plombier Urgence">
        <input type="hidden" name="_captcha" value="true">
        <input type="hidden" name="_template" value="box">
        <input type="text" name="_honey" style="display:none">

        <h3 class="contact-form__title">📋 Devis Gratuit en 2 min</h3>

        <div class="form-group">
          <label for="name">Nom complet *</label>
          <input type="text" id="name" name="name" placeholder="Votre nom" required>
        </div>

        <div class="form-group">
          <label for="phone">Téléphone *</label>
          <input type="tel" id="phone" name="phone" placeholder="0465 68 51 58" required>
        </div>

        <div class="form-group">
          <label for="message">Décrivez votre problème *</label>
          <textarea id="message" name="message" rows="4" placeholder="Décrivez le problème, l'adresse, et vos disponibilités..." required></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-lg form-submit">
          Envoyer la Demande de Devis →
        </button>

        <p class="form-note">🔒 Vos données sont privées. Réponse en moins de 15 min.</p>
      </form>
    </div>
  </div>
</section>

<style>
  .label{font-size:var(--font-size-sm);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-accent);margin-bottom:var(--space-sm)}

  .contact-section{padding:var(--space-3xl) 0}
  .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-3xl);align-items:start}

  .contact-info__title{font-size:var(--font-size-3xl);font-weight:900;line-height:1.2;margin-bottom:var(--space-md)}
  .contact-info__text{color:var(--color-text-muted);font-size:var(--font-size-lg);line-height:1.7;margin-bottom:var(--space-xl)}

  .contact-info__items{display:flex;flex-direction:column;gap:var(--space-md);margin-bottom:var(--space-xl)}
  .contact-info__item{display:flex;align-items:center;gap:var(--space-md);padding:var(--space-md);border-radius:var(--radius-lg);background:var(--color-surface);border:1px solid var(--color-border);text-decoration:none;color:var(--color-text);transition:border-color var(--transition-fast)}
  .contact-info__item:hover{border-color:var(--color-accent)}
  .contact-info__icon{font-size:1.5rem}
  .contact-info__item div{display:flex;flex-direction:column;gap:2px}
  .contact-info__item strong{font-size:var(--font-size-sm);font-weight:700}
  .contact-info__item span{font-size:var(--font-size-xs);color:var(--color-text-dim)}

  .contact-trust{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-sm)}
  .trust-badge{display:flex;align-items:center;gap:var(--space-sm);font-size:var(--font-size-xs);font-weight:600;color:var(--color-text-muted)}
  .trust-badge__icon{font-size:1rem}

  /* Form */
  .contact-form{padding:var(--space-2xl)}
  .contact-form__title{font-size:var(--font-size-xl);font-weight:800;margin-bottom:var(--space-xl);text-align:center}

  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:var(--space-md)}
  .form-group{margin-bottom:var(--space-md)}
  .form-group label{display:block;font-size:var(--font-size-sm);font-weight:600;margin-bottom:var(--space-xs);color:var(--color-text-muted)}
  .form-group input,.form-group select,.form-group textarea{width:100%;padding:.7rem 1rem;background:var(--color-bg);border:1px solid var(--color-border);border-radius:var(--radius-md);color:var(--color-text);font-size:var(--font-size-sm);font-family:inherit;transition:border-color var(--transition-fast)}
  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:var(--color-accent);box-shadow:0 0 0 3px rgba(80,160,226,.1)}
  .form-group input::placeholder,.form-group textarea::placeholder{color:var(--color-text-dim)}
  .form-group select{cursor:pointer}
  .form-group textarea{resize:vertical;min-height:80px}

  .form-submit{width:100%;justify-content:center;margin-top:var(--space-md)}
  .form-note{text-align:center;font-size:var(--font-size-xs);color:var(--color-text-dim);margin-top:var(--space-md)}

  @media(max-width:768px){
    .contact-grid{grid-template-columns:1fr}
    .form-row{grid-template-columns:1fr}
  }
</style>
