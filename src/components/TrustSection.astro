---
/**
 * Trust section — shows on every page via Layout
 * Years in business, certifications, guarantees, response time, review badge, GBP embed
 */
---

<!-- Trust Stats Bar -->
<section class="trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      <div class="trust-bar__item">
        <span class="trust-bar__num">15+</span>
        <span class="trust-bar__label">Années d'expérience</span>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <span class="trust-bar__num">5 000+</span>
        <span class="trust-bar__label">Clients satisfaits</span>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <span class="trust-bar__num">30 min</span>
        <span class="trust-bar__label">Temps de réponse</span>
      </div>
      <div class="trust-bar__divider"></div>
      <div class="trust-bar__item">
        <span class="trust-bar__num">4.9/5</span>
        <span class="trust-bar__label">Avis Google (500+)</span>
      </div>
    </div>
  </div>
</section>

<!-- Trust Badges -->
<section class="trust-badges">
  <div class="container">
    <div class="trust-badges__grid">
      <div class="tbadge">
        <div class="tbadge__icon">🏆</div>
        <h3 class="tbadge__title">15+ Ans d'Expérience</h3>
        <p class="tbadge__text">Plombiers professionnels depuis 2009. Plus de 5 000 interventions réussies en Belgique.</p>
      </div>
      <div class="tbadge">
        <div class="tbadge__icon">📜</div>
        <h3 class="tbadge__title">Certifié & Agréé</h3>
        <p class="tbadge__text">Chauffagistes agréés Cerga/Cedicol. Conformes aux normes belges et européennes.</p>
      </div>
      <div class="tbadge">
        <div class="tbadge__icon">🛡️</div>
        <h3 class="tbadge__title">Garantie 2 Ans</h3>
        <p class="tbadge__text">Toutes nos réparations et installations sont garanties 2 ans pièces et main d'œuvre.</p>
      </div>
      <div class="tbadge">
        <div class="tbadge__icon">⚡</div>
        <h3 class="tbadge__title">30 Min Chrono</h3>
        <p class="tbadge__text">Temps de réponse moyen de 30 minutes. Disponible 24h/24, 7j/7, 365 jours par an.</p>
      </div>
      <div class="tbadge">
        <div class="tbadge__icon">💰</div>
        <h3 class="tbadge__title">Prix Fixe Garanti</h3>
        <p class="tbadge__text">Le prix est communiqué AVANT l'intervention. Pas de supplément surprise, jamais.</p>
      </div>
      <div class="tbadge">
        <div class="tbadge__icon">⭐</div>
        <h3 class="tbadge__title">4.9/5 sur Google</h3>
        <p class="tbadge__text">Plus de 500 avis vérifiés sur Google. Le plombier le mieux noté de Belgique.</p>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="trust-reviews">
  <div class="container text-center">
    <p class="label">Avis clients vérifiés</p>
    <h2 class="section-title">Ce que Disent Nos Clients</h2>
  </div>
  <div class="container">
    <div class="reviews-grid">
      <div class="review-card card">
        <div class="review-card__stars">★★★★★</div>
        <p class="review-card__text">"Intervention en moins de 20 minutes pour une fuite urgente un dimanche soir. Travail propre et soigné. Prix annoncé respecté. Je recommande vivement !"</p>
        <div class="review-card__author"><div class="review-card__avatar">ML</div><div><strong>Marie L.</strong><span>Bruxelles — Google</span></div></div>
      </div>
      <div class="review-card card">
        <div class="review-card__stars">★★★★★</div>
        <p class="review-card__text">"Chaudière réparée en une heure. Très professionnel, a tout expliqué clairement. Tarif correct et facture immédiate. Merci !"</p>
        <div class="review-card__author"><div class="review-card__avatar">PD</div><div><strong>Pierre D.</strong><span>Waterloo — Google</span></div></div>
      </div>
      <div class="review-card card">
        <div class="review-card__stars">★★★★★</div>
        <p class="review-card__text">"J'ai envoyé une photo par WhatsApp, j'ai eu un prix en 5 minutes et le plombier était là en 25 min. C'est la première fois qu'un plombier affiche ses prix. Enfin !"</p>
        <div class="review-card__author"><div class="review-card__avatar">SB</div><div><strong>Sophie B.</strong><span>Namur — Google</span></div></div>
      </div>
      <div class="review-card card">
        <div class="review-card__stars">★★★★★</div>
        <p class="review-card__text">"Rénovation complète de notre salle de bain. Résultat magnifique, dans le budget annoncé et dans les délais. Équipe sérieuse et soignée."</p>
        <div class="review-card__author"><div class="review-card__avatar">JM</div><div><strong>Jean M.</strong><span>Liège — Google</span></div></div>
      </div>
    </div>
    <!-- Google Review Badge -->
    <div class="review-badge">
      <div class="review-badge__inner">
        <span class="review-badge__stars">⭐⭐⭐⭐⭐</span>
        <span class="review-badge__score">4.9/5</span>
        <span class="review-badge__count">Basé sur 500+ avis Google vérifiés</span>
        <a href="https://maps.app.goo.gl/i7W6nLrabKjKykHE9" target="_blank" rel="noopener" class="review-badge__link">Voir tous les avis sur Google →</a>
      </div>
    </div>
  </div>
</section>

<!-- Google Business Profile Map Embed -->
<section class="trust-map">
  <div class="container">
    <p class="label text-center">Trouvez-nous</p>
    <h2 class="section-title text-center">Notre Position sur Google Maps</h2>
    <div class="map-wrap">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2518.2!2d4.3517!3d50.8503!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTDCsDUxJzAxLjEiTiA0wrAyMScwNi4xIkU!5e0!3m2!1sfr!2sbe!4v1"
        width="100%"
        height="400"
        style="border:0;border-radius:var(--radius-xl);"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Plombier Urgence — Google Maps"
      ></iframe>
    </div>
    <div class="map-cta">
      <a href="https://maps.app.goo.gl/i7W6nLrabKjKykHE9" target="_blank" rel="noopener" class="btn btn-outline">Voir sur Google Maps →</a>
    </div>
  </div>
</section>

<style>
  .label{font-size:var(--font-size-sm);font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--color-accent);margin-bottom:var(--space-sm)}

  /* Stats Bar */
  .trust-bar{background:var(--color-accent);padding:var(--space-xl) 0}
  .trust-bar__grid{display:flex;align-items:center;justify-content:center;gap:var(--space-2xl)}
  .trust-bar__item{display:flex;flex-direction:column;align-items:center;gap:4px}
  .trust-bar__num{font-size:var(--font-size-2xl);font-weight:900;color:#fff}
  .trust-bar__label{font-size:var(--font-size-xs);color:rgba(255,255,255,.8);font-weight:500}
  .trust-bar__divider{width:1px;height:40px;background:rgba(255,255,255,.2)}

  /* Badges */
  .trust-badges{padding:var(--space-3xl) 0;background:var(--color-bg-alt)}
  .trust-badges__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-lg)}
  .tbadge{text-align:center;padding:var(--space-xl);background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-lg)}
  .tbadge__icon{font-size:2rem;margin-bottom:var(--space-sm)}
  .tbadge__title{font-size:var(--font-size-base);font-weight:700;margin-bottom:var(--space-xs)}
  .tbadge__text{font-size:var(--font-size-sm);color:var(--color-text-muted);line-height:1.7}

  /* Reviews */
  .trust-reviews{padding:var(--space-3xl) 0}
  .reviews-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-lg);margin-top:var(--space-xl)}
  .review-card{padding:var(--space-xl);display:flex;flex-direction:column;gap:var(--space-md)}
  .review-card__stars{color:#f59e0b;font-size:1.1rem;letter-spacing:2px}
  .review-card__text{font-size:var(--font-size-sm);color:var(--color-text-muted);line-height:1.7;flex:1;font-style:italic}
  .review-card__author{display:flex;align-items:center;gap:var(--space-sm)}
  .review-card__avatar{width:36px;height:36px;border-radius:50%;background:var(--color-accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:var(--font-size-xs)}
  .review-card__author strong{font-size:var(--font-size-sm)}
  .review-card__author span{display:block;font-size:var(--font-size-xs);color:var(--color-text-dim)}

  .review-badge{text-align:center;margin-top:var(--space-2xl)}
  .review-badge__inner{display:inline-flex;flex-direction:column;align-items:center;gap:var(--space-sm);padding:var(--space-xl) var(--space-2xl);background:var(--color-surface);border:2px solid var(--color-accent);border-radius:var(--radius-xl)}
  .review-badge__stars{font-size:1.4rem;letter-spacing:-1px}
  .review-badge__score{font-size:var(--font-size-3xl);font-weight:900;color:var(--color-accent)}
  .review-badge__count{font-size:var(--font-size-sm);color:var(--color-text-muted)}
  .review-badge__link{font-size:var(--font-size-sm);color:var(--color-accent);font-weight:700}

  /* Map */
  .trust-map{padding:var(--space-3xl) 0;background:var(--color-bg-alt)}
  .map-wrap{margin-top:var(--space-xl);border-radius:var(--radius-xl);overflow:hidden;border:1px solid var(--color-border)}
  .map-cta{text-align:center;margin-top:var(--space-lg)}

  @media(max-width:1024px){
    .trust-badges__grid{grid-template-columns:repeat(2,1fr)}
    .reviews-grid{grid-template-columns:repeat(2,1fr)}
  }
  @media(max-width:768px){
    .trust-bar__grid{flex-wrap:wrap;gap:var(--space-lg)}
    .trust-bar__divider{display:none}
    .trust-badges__grid{grid-template-columns:1fr}
    .reviews-grid{grid-template-columns:1fr}
  }
</style>
