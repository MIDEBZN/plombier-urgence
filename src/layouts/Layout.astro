---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustSection from '../components/TrustSection.astro';
import ContactForm from '../components/ContactForm.astro';
import '../styles/global.css';
import { getAllCommunes } from '../data/communes';

const allCommunesList = getAllCommunes();
const allCommunesAreaServed = allCommunesList.map(c => ({
  "@type": "City",
  "name": c.name
}));
allCommunesAreaServed.push({ "@type": "Country", "name": "Belgique" });

interface Props {
  title: string;
  description?: string;
  faqs?: { q: string; a: string }[];
  ogImage?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  extraSchemas?: object[];
  areaServed?: { "@type": string; "name": string }[];
  preloadHero?: boolean;
  robots?: string;
}

const { 
  title, 
  description = "Plombier d'urgence Belgique — Intervention rapide 24h/24, 7j/7. Tarifs 2025. Prix affichés avant intervention. Débouchage dès 60€, fuites dès 95€. Bruxelles, Liège, Namur, Charleroi. ☎ 0465 68 51 58", 
  faqs = [],
  ogImage = 'https://www.plombierurgence.be/images/og-default.jpg',
  ogType = 'website',
  twitterTitle,
  twitterDescription,
  extraSchemas = [],
  areaServed = allCommunesAreaServed,
  preloadHero = false,
  robots = "index, follow"
} = Astro.props;

// LocalBusiness schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "Plumber"],
  "name": "Plombier Urgence",
  "description": "Plombier d'urgence en Belgique. Intervention en 30 minutes, 24h/24 et 7j/7. Débouchage dès 60€, réparation fuite dès 95€, dépannage chaudière dès 150€. Prix fixe avant intervention. Certifié et agréé.",
  "url": "https://www.plombierurgence.be",
  "telephone": "+32465685158",
  "email": "contact@plombierurgence.be",
  "priceRange": "60€–500€",
  "currenciesAccepted": "EUR",
  "paymentAccepted": "Cash, Card, Bank Transfer",
  "image": "https://www.plombierurgence.be/images/og-default.jpg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bruxelles",
    "addressLocality": "Bruxelles",
    "addressRegion": "Bruxelles-Capitale",
    "postalCode": "1000",
    "addressCountry": "BE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "50.8503",
    "longitude": "4.3517"
  },
  "knowsLanguage": [
    {
      "@type": "Language",
      "name": "French",
      "alternateName": "fr"
    },
    {
      "@type": "Language",
      "name": "Dutch",
      "alternateName": "nl"
    }
  ],
  "openingHours": "Mo-Su 00:00-23:59",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "areaServed": areaServed,
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "523",
    "bestRating": "5"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Services de plomberie",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": { "@type": "Service", "name": "Débouchage canalisation" },
        "price": "60",
        "priceCurrency": "EUR",
        "eligibleRegion": "Belgique"
      },
      {
        "@type": "Offer",
        "itemOffered": { "@type": "Service", "name": "Réparation fuite d'eau" },
        "price": "95",
        "priceCurrency": "EUR"
      },
      {
        "@type": "Offer",
        "itemOffered": { "@type": "Service", "name": "Dépannage chaudière" },
        "price": "150",
        "priceCurrency": "EUR"
      },
      {
        "@type": "Offer",
        "itemOffered": { "@type": "Service", "name": "Inspection caméra canalisation" },
        "price": "120",
        "priceCurrency": "EUR"
      }
    ]
  },
  "hasCredential": [
    {
      "@type": "EducationalOccupationalCredential",
      "credentialCategory": "Certification",
      "name": "Certification CP1/CP2 Synergrid"
    }
  ],
  "foundingDate": "2009",
  "sameAs": [
    "https://www.instagram.com/plom.bierurgence/",
    "https://www.tiktok.com/@plombierurgence",
    "https://www.facebook.com/plombierurgencee/",
    "https://www.pinterest.com/PlombierUrgenceBruxelles/",
    "https://www.youtube.com/@PlombierUrgenceBruxelles",
    "https://fr-be.trustpilot.com/review/plombierurgence.be",
    "https://maps.app.goo.gl/o5ncKidk5CEoTWMr8",
    "https://sites.google.com/view/plombier-urgence-bxl/accueil"
  ]
};

// FAQ schema
const faqSchema = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
} : null;

const isThankYou = Astro.url.pathname.includes('thank-you');

// Canonical: use www for all pages
const canonicalPath = Astro.url.pathname === '/' ? '/' : (Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/');
const canonicalUrl = new URL(canonicalPath, 'https://www.plombierurgence.be').href;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `https://www.plombierurgence.be${ogImage}`;
const resolvedTwitterTitle = twitterTitle || title;
const resolvedTwitterDescription = twitterDescription || description;

// WebPage schema with BreadcrumbList
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": canonicalUrl,
  "inLanguage": "fr-BE",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Plombier Urgence",
    "url": "https://www.plombierurgence.be"
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Accueil",
        "item": "https://www.plombierurgence.be/"
      },
      Astro.url.pathname !== '/' ? {
        "@type": "ListItem",
        "position": 2,
        "name": title.split('—')[0].trim(),
        "item": canonicalUrl
      } : null
    ].filter(Boolean)
  }
};

const allSchemas = [...extraSchemas, webPageSchema];

// Auto-inject Article Schema for blog posts
const isBlog = Astro.url.pathname.startsWith('/blog/') && Astro.url.pathname !== '/blog/' && Astro.url.pathname !== '/blog';
if (isBlog) {
  const articleSchema = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "image": resolvedOgImage,
    "author": {
      "@type": "Organization",
      "name": "Plombier Urgence"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Plombier Urgence",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.plombierurgence.be/favicon.png"
      }
    },
    "datePublished": "2025-02-15T08:00:00+01:00",
    "dateModified": new Date().toISOString()
  };
  allSchemas.push(articleSchema);
}
---

<!doctype html>
<html lang="fr">
  <head>

    <!-- Google tag (gtag.js) - Deferred -->
    <script is:inline>
      let gtagLoaded = false;
      function loadGtag() {
        if (gtagLoaded) return;
        gtagLoaded = true;
        const script = document.createElement('script');
        script.src = 'https://www.googletagmanager.com/gtag/js?id=AW-17876130811';
        script.async = true;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag; // Make globally accessible
        gtag('js', new Date());
        gtag('config', 'AW-17876130811');
        gtag('config', 'AW-17876130811/WvKSCJXeqoIcEPu3gMxC', {
          'phone_conversion_number': '0465 68 51 58'
        });
      }

      ['scroll', 'mousemove', 'touchstart', 'keydown'].forEach(event => {
        window.addEventListener(event, loadGtag, { once: true, passive: true });
      });
      
      setTimeout(loadGtag, 8000); // Deferred fallback for better LCP/TBT
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    {preloadHero && (
      <link rel="preload" as="image" href="/images/hero-bg.webp" fetchpriority="high" />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="fr_BE" />
    <meta property="og:site_name" content="Plombier Urgence" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTwitterTitle} />
    <meta name="twitter:description" content={resolvedTwitterDescription} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <title>{title}</title>

    <!-- Schema: LocalBusiness (Global) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Schema: FAQ (if provided) -->
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}

    <!-- Schema: Extra per-page schemas + WebPage -->
    {allSchemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <!-- Emergency Hotline Banner -->
    <div class="emergency-banner" id="emergency-banner">
      <div class="container emergency-banner__inner">
        <span class="emergency-banner__text">🚨 <strong>Urgence Plomberie ?</strong> Intervention en 30 min — 24h/24</span>
        <a href="tel:0465685158" class="emergency-banner__cta">📞 0465 68 51 58</a>
        <button class="emergency-banner__close" id="close-banner" aria-label="Fermer">✕</button>
      </div>
    </div>

    <Header />
    <main>
      <slot />
    </main>

    <!-- Trust Section (on every page except thank-you) -->
    {!isThankYou && <TrustSection />}

    <!-- Contact Form (on every page except thank-you) -->
    {!isThankYou && <ContactForm />}

    <Footer />

    <!-- Floating WhatsApp Button -->
    <a
      href="https://wa.me/32465685158?text=Bonjour%2C%20j%27ai%20besoin%20d%27un%20plombier%20urgence"
      class="float-wa"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactez-nous sur WhatsApp"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span class="float-wa__label">Envoyez une photo</span>
    </a>

    <!-- Floating Appeler Button -->
    <a href="tel:0465685158" class="float-call" aria-label="Appeler">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="#fff"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
      <span class="float-call__label">Appeler</span>
    </a>
  </body>
</html>

<style is:global>
  /* Emergency Banner */
  .emergency-banner {
    background: linear-gradient(90deg, #ef4444, #dc2626);
    color: #fff;
    padding: 0.5rem 0;
    font-size: 0.85rem;
    position: relative;
    z-index: 1002;
  }
  .emergency-banner__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  .emergency-banner__text { font-weight: 500; }
  .emergency-banner__cta {
    background: #fff;
    color: #dc2626;
    padding: 0.3rem 1rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .emergency-banner__cta:hover { transform: scale(1.05); }
  .emergency-banner__close {
    background: none;
    border: none;
    color: rgba(255,255,255,.7);
    font-size: 1rem;
    cursor: pointer;
    padding: 0 0.5rem;
  }
  .emergency-banner--hidden { display: none; }

  /* Floating WhatsApp */
  .float-wa {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 998;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #25d366;
    color: #fff;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.85rem;
    transition: all 0.2s;
    animation: float-pulse 3s ease-in-out infinite;
  }
  .float-wa:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 30px rgba(37, 211, 102, 0.5);
  }
  @keyframes float-pulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4); }
    50% { box-shadow: 0 4px 30px rgba(37, 211, 102, 0.6); }
  }

  /* Floating Appeler */
  .float-call {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 998;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-accent);
    color: #fff;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    box-shadow: 0 4px 20px rgba(80, 160, 226, 0.4);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.85rem;
    transition: all 0.2s;
    animation: float-pulse-call 3s ease-in-out infinite;
  }
  .float-call:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 30px rgba(80, 160, 226, 0.5);
  }
  @keyframes float-pulse-call {
    0%, 100% { box-shadow: 0 4px 20px rgba(80, 160, 226, 0.4); }
    50% { box-shadow: 0 4px 30px rgba(80, 160, 226, 0.6); }
  }

  @media (max-width: 768px) {
    .float-wa__label { display: none; }
    .float-wa { padding: 0.85rem; }
    .float-call__label { display: none; }
    .float-call { padding: 0.85rem; }
    .emergency-banner__text { font-size: 0.75rem; }
    .emergency-banner__inner { gap: 0.5rem; }
  }
</style>

<script>
  // Emergency banner close
  const banner = document.getElementById('emergency-banner');
  const closeBtn = document.getElementById('close-banner');
  closeBtn?.addEventListener('click', () => {
    banner?.classList.add('emergency-banner--hidden');
  });
</script>
