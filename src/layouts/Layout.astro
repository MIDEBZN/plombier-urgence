---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TrustSection from '../components/TrustSection.astro';
import ContactForm from '../components/ContactForm.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  faqs?: { q: string; a: string }[];
}

const { title, description = "Plombier d'urgence Bruxelles & Belgique — Intervention rapide 24h/24, 7j/7. Tarifs clairs 2025. Prix affichés avant intervention. Débouchage, fuites, chaudières. ☎ 0470 12 34 56", faqs = [] } = Astro.props;

// LocalBusiness schema
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "Plumber",
  "name": "Plombier Urgence",
  "description": "Plombier d'urgence en Belgique — Intervention rapide 24h/24 et 7j/7. Tarifs clairs 2025, prix affichés. Bruxelles, Liège, Namur, Charleroi, Mons.",
  "url": "https://plombierurgence.be",
  "telephone": "+32470123456",
  "email": "midebzn@gmail.com",
  "priceRange": "€€",
  "image": "https://plombierurgence.be/og-image.jpg",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Bruxelles",
    "addressLocality": "Bruxelles",
    "addressRegion": "Bruxelles-Capitale",
    "postalCode": "1000",
    "addressCountry": "BE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "50.8503",
    "longitude": "4.3517"
  },
  "areaServed": [
    { "@type": "City", "name": "Bruxelles" },
    { "@type": "City", "name": "Liège" },
    { "@type": "City", "name": "Namur" },
    { "@type": "City", "name": "Charleroi" },
    { "@type": "City", "name": "Mons" },
    { "@type": "City", "name": "Waterloo" },
    { "@type": "City", "name": "Wavre" }
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9",
    "reviewCount": "523",
    "bestRating": "5"
  },
  "foundingDate": "2009",
  "sameAs": [
    "https://maps.app.goo.gl/i7W6nLrabKjKykHE9"
  ]
};

// FAQ schema
const faqSchema = faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
} : null;

const isThankYou = Astro.url.pathname.includes('thank-you');
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`https://plombierurgence.be${Astro.url.pathname}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_BE" />
    <meta property="og:site_name" content="Plombier Urgence" />

    <title>{title}</title>

    <!-- Schema: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    <!-- Schema: FAQ (if provided) -->
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </head>
  <body>
    <!-- Emergency Hotline Banner -->
    <div class="emergency-banner" id="emergency-banner">
      <div class="container emergency-banner__inner">
        <span class="emergency-banner__text">🚨 <strong>Urgence Plomberie ?</strong> Intervention en 30 min — 24h/24</span>
        <a href="tel:0470123456" class="emergency-banner__cta">📞 0470 12 34 56</a>
        <button class="emergency-banner__close" id="close-banner" aria-label="Fermer">✕</button>
      </div>
    </div>

    <Header />
    <main style="padding-top: 72px;">
      <slot />
    </main>

    <!-- Trust Section (on every page except thank-you) -->
    {!isThankYou && <TrustSection />}

    <!-- Contact Form (on every page except thank-you) -->
    {!isThankYou && <ContactForm />}

    <Footer />

    <!-- Floating WhatsApp Button -->
    <a
      href="https://wa.me/32470123456?text=Bonjour%2C%20j%27ai%20besoin%20d%27un%20plombier%20urgence"
      class="float-wa"
      target="_blank"
      rel="noopener"
      aria-label="Contactez-nous sur WhatsApp"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="#fff"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span class="float-wa__label">Envoyez une photo</span>
    </a>

    <!-- Floating Phone Button (mobile only) -->
    <a href="tel:0470123456" class="float-phone" aria-label="Appeler">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="#fff"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
    </a>

    <!-- Live Chat Widget -->
    <div class="chat-widget" id="chat-widget">
      <button class="chat-widget__trigger" id="chat-trigger" aria-label="Chat">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="#fff"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H6l-2 2V4h16v12z"/></svg>
      </button>
      <div class="chat-widget__panel" id="chat-panel">
        <div class="chat-widget__header">
          <strong>💬 Chat Rapide</strong>
          <button class="chat-widget__close" id="chat-close">✕</button>
        </div>
        <div class="chat-widget__body">
          <div class="chat-msg chat-msg--bot">
            <p>Bonjour ! 👋 Comment puis-je vous aider ?</p>
          </div>
          <div class="chat-msg chat-msg--bot">
            <p>Pour une réponse <strong>immédiate</strong>, choisissez :</p>
          </div>
          <div class="chat-quick">
            <a href="tel:0470123456" class="chat-quick__btn">📞 Appeler</a>
            <a href="https://wa.me/32470123456" target="_blank" class="chat-quick__btn chat-quick__btn--wa">💬 WhatsApp</a>
            <a href="#contact-form" class="chat-quick__btn" id="chat-form-link">📋 Devis gratuit</a>
          </div>
          <div class="chat-msg chat-msg--bot">
            <p>Ou envoyez une <strong>photo du problème par WhatsApp</strong> pour un diagnostic et prix en 5 min.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Get Quote Sticky Bottom Bar (mobile) -->
    <div class="sticky-bottom" id="sticky-bottom">
      <a href="tel:0470123456" class="sticky-bottom__call">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#fff"><path d="M6.62 10.79a15.053 15.053 0 006.59 6.59l2.2-2.2a1.003 1.003 0 011.01-.24c1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.1.31.03.66-.25 1.02l-2.2 2.2z"/></svg>
        Appeler
      </a>
      <a href="#contact-form" class="sticky-bottom__quote">📋 Devis Gratuit</a>
    </div>
  </body>
</html>

<style is:global>
  /* Emergency Banner */
  .emergency-banner {
    background: linear-gradient(90deg, #ef4444, #dc2626);
    color: #fff;
    padding: 0.5rem 0;
    font-size: 0.85rem;
    position: relative;
    z-index: 1002;
  }
  .emergency-banner__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  .emergency-banner__text { font-weight: 500; }
  .emergency-banner__cta {
    background: #fff;
    color: #dc2626;
    padding: 0.3rem 1rem;
    border-radius: 999px;
    font-weight: 800;
    font-size: 0.85rem;
    text-decoration: none;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .emergency-banner__cta:hover { transform: scale(1.05); }
  .emergency-banner__close {
    background: none;
    border: none;
    color: rgba(255,255,255,.7);
    font-size: 1rem;
    cursor: pointer;
    padding: 0 0.5rem;
  }
  .emergency-banner--hidden { display: none; }

  /* Floating WhatsApp */
  .float-wa {
    position: fixed;
    bottom: 90px;
    right: 24px;
    z-index: 998;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #25d366;
    color: #fff;
    padding: 0.85rem 1.2rem;
    border-radius: 999px;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.85rem;
    transition: all 0.2s;
    animation: float-pulse 3s ease-in-out infinite;
  }
  .float-wa:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 30px rgba(37, 211, 102, 0.5);
  }
  @keyframes float-pulse {
    0%, 100% { box-shadow: 0 4px 20px rgba(37, 211, 102, 0.4); }
    50% { box-shadow: 0 4px 30px rgba(37, 211, 102, 0.6); }
  }

  /* Floating phone (mobile) */
  .float-phone {
    display: none;
    position: fixed;
    bottom: 90px;
    left: 24px;
    z-index: 998;
    background: var(--color-accent);
    color: #fff;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(80, 160, 226, 0.4);
    text-decoration: none;
    animation: float-pulse-phone 3s ease-in-out infinite;
  }
  @keyframes float-pulse-phone {
    0%, 100% { box-shadow: 0 4px 20px rgba(80, 160, 226, 0.4); }
    50% { box-shadow: 0 4px 30px rgba(80, 160, 226, 0.6); }
  }

  /* Chat Widget */
  .chat-widget {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
  }
  .chat-widget__trigger {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-accent);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(80, 160, 226, 0.4);
    transition: all 0.2s;
  }
  .chat-widget__trigger:hover { transform: scale(1.1); }
  .chat-widget__panel {
    display: none;
    position: absolute;
    bottom: 70px;
    right: 0;
    width: 320px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: 0 12px 40px rgba(0,0,0,.5);
    overflow: hidden;
  }
  .chat-widget__panel.open { display: block; }
  .chat-widget__header {
    background: var(--color-accent);
    color: #fff;
    padding: 0.8rem 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.9rem;
  }
  .chat-widget__close {
    background: none;
    border: none;
    color: rgba(255,255,255,.8);
    font-size: 1.1rem;
    cursor: pointer;
  }
  .chat-widget__body { padding: 1rem; }
  .chat-msg { margin-bottom: 0.8rem; }
  .chat-msg--bot p {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: 0.7rem 1rem;
    border-radius: 0 12px 12px 12px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }
  .chat-quick {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 0.8rem;
  }
  .chat-quick__btn {
    display: block;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    transition: all 0.2s;
  }
  .chat-quick__btn:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .chat-quick__btn--wa { background: #25d366; color: #fff; border-color: #25d366; }
  .chat-quick__btn--wa:hover { background: #1ebe57; color: #fff; }

  /* Sticky Bottom Bar (mobile) */
  .sticky-bottom {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 997;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding: 0.6rem;
    gap: 0.5rem;
  }
  .sticky-bottom__call {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: var(--color-accent);
    color: #fff;
    padding: 0.7rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
  }
  .sticky-bottom__quote {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: #25d366;
    color: #fff;
    padding: 0.7rem;
    border-radius: var(--radius-md);
    font-weight: 700;
    font-size: 0.85rem;
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .float-wa__label { display: none; }
    .float-wa { padding: 0.85rem; bottom: 150px; }
    .float-phone { display: flex; bottom: 150px; }
    .sticky-bottom { display: flex; }
    .chat-widget { bottom: 72px; right: 16px; }
    .chat-widget__panel { width: 290px; }
    .emergency-banner__text { font-size: 0.75rem; }
    .emergency-banner__inner { gap: 0.5rem; }
  }
</style>

<script>
  // Emergency banner close
  const banner = document.getElementById('emergency-banner');
  const closeBtn = document.getElementById('close-banner');
  closeBtn?.addEventListener('click', () => {
    banner?.classList.add('emergency-banner--hidden');
  });

  // Chat widget toggle
  const chatTrigger = document.getElementById('chat-trigger');
  const chatPanel = document.getElementById('chat-panel');
  const chatClose = document.getElementById('chat-close');
  const chatFormLink = document.getElementById('chat-form-link');

  chatTrigger?.addEventListener('click', () => {
    chatPanel?.classList.toggle('open');
  });
  chatClose?.addEventListener('click', () => {
    chatPanel?.classList.remove('open');
  });
  chatFormLink?.addEventListener('click', () => {
    chatPanel?.classList.remove('open');
  });
</script>
